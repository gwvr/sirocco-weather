default: home

locations:
  home:
    name: London, UK
    lat: 51.5074
    lon: -0.1278
    timezone: Europe/London
    model: ukmo_seamless        # optional: weather model (default: ECMWF)
    wind_units: mph             # optional: mph or kmh (default: kmh)
    precip_model: ecmwf_ifs025  # optional: secondary model for precipitation

